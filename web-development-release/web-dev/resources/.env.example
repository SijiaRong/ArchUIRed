# Copy this file to .env.local and fill in values for your environment.

# Filesystem access mode: "fsa" (File System Access API) or "server"
VITE_FS_MODE=fsa

# Dev server URL (used in "server" mode)
VITE_SERVER_URL=http://localhost:3001

# Optional: Figma MCP endpoint for design sync
# VITE_FIGMA_MCP_ENDPOINT=
